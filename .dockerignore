# Ignore everything by default
*

# Allow the Dockerfile and .dockerignore themselves
!Dockerfile
!.dockerignore

# Allow the backend directory and its essential build files
!backend/
backend/target/
backend/*.log
backend/.idea/
backend/.vscode/

# Ensure wrapper and pom are NOT ignored (even though !backend/ should cover it, being explicit is safer)
!backend/mvnw
!backend/mvnw.cmd
!backend/.mvn/
!backend/pom.xml
